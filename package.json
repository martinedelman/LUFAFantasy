{
  "name": "lufa_fantasy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "seed": "node --env-file=.env --import tsx scripts/seed.ts",
    "db:sync-test-from-prod": "node --env-file=.env --import tsx scripts/sync-test-db-from-prod.ts",
    "vercel:pull:testing": "vercel pull --yes --environment=preview",
    "vercel:pull:prod": "vercel pull --yes --environment=production",
    "deploy:testing": "vercel deploy --yes --name lufa-fantasy",
    "deploy:prod": "vercel deploy --prod --yes --name lufa-fantasy"
  },
  "dependencies": {
    "@flags-sdk/vercel": "^1.3.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mongoose": "^5.11.97",
    "@types/nodemailer": "^8.0.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.3.3",
    "bcryptjs": "^3.0.2",
    "flags": "^4.0.6",
    "googleapis": "^172.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.16.0",
    "next": "^15.5.6",
    "nodemailer": "^8.0.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.5.6",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.3",
    "typescript": "^5"
  }
}
