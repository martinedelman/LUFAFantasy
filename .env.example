# =====================================================
# APP / ENTORNO
# =====================================================
# Valores permitidos: development | production
environment=development

# URL pública de la app (requerida en producción para links de verificación)
NEXT_PUBLIC_APP_URL=http://localhost:3000


# =====================================================
# BASE DE DATOS
# =====================================================
# Requerida: cadena de conexión MongoDB (usada por src/lib/mongodb.ts)
MONGODB_URI=mongodb://localhost:27017/lufa_fantasy


# =====================================================
# AUTENTICACIÓN Y SESIONES
# =====================================================
# Requerida: secreto para firma JWT de sesión por cookie
JWT_SECRET=change-this-to-a-long-random-secret

# Opcional: secreto específico para OTP (si falta, se usa JWT_SECRET)
OTP_SECRET=change-this-to-a-long-random-otp-secret

# Opcionales para futuras fases (no usados en el MVP actual)
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=change-me


# =====================================================
# EMAIL (Nodemailer + ZeptoMail)
# =====================================================
# Requeridas en producción para envío de emails
MAIL_FROM="LUFA Flag <no-reply@lufa.com.uy>"
MAIL_PROVIDER=zeptomail

# Usar las credenciales SMTP de ZeptoMail.
SMTP_HOST=smtp.zeptomail.com
SMTP_PORT=465
SMTP_SECURE=true

SMTP_USER=emailapikey
SMTP_PASS=your-zeptomail-smtp-password


# =====================================================
# STORAGE (Vercel Blob)
# =====================================================
# Requerida: token read/write de Vercel Blob
# Usada en src/services/backend/BlobStorageService.ts
BLOB_READ_WRITE_TOKEN=vercel_blob


# =====================================================
# FEATURE FLAGS (Vercel)
# =====================================================
# Requeridas en producción:
# - FLAGS se autoprovisiona al crear la primera flag en Vercel.
# - FLAGS_SECRET debe ser exactamente 32 bytes aleatorios en base64.
FLAGS=vercel_flags_sdk_key
FLAGS_SECRET=base64-encoded-32-random-bytes


# =====================================================
# CRON + IMPORTACIÓN DESDE GOOGLE SHEETS
# =====================================================
# Requeridas para tareas cron e importación de jugadores
CRON_SECRET=change-this-to-a-long-random-cron-secret
GOOGLE_SHEETS_SPREADSHEET_ID=your-google-sheet-id
GOOGLE_SHEETS_TAB_NAME=Respuestas de formulario 1
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project.iam.gserviceaccount.com

# Mantener \n escapado para preservar saltos de línea de la clave privada
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
