# Environment: production | development
environment=development

# Requerida: cadena de conexión de MongoDB usada por src/lib/mongodb.ts
MONGODB_URI=mongodb://localhost:27017/lufa_fantasy

# Requerida: firma de sesión JWT para autenticación por cookie
JWT_SECRET=change-this-to-a-long-random-secret

# Requerida: token de lectura/escritura para Vercel Blob Storage (usado en src/services/backend/BlobStorageService.ts)
BLOB_READ_WRITE_TOKEN=vercel_blob

# Requeridas por Vercel Feature Flags en producción
# FLAGS se autoprovisiona al crear la primera flag en Vercel.
# FLAGS_SECRET debe ser exactamente 32 bytes aleatorios codificados en base64.
FLAGS=vercel_flags_sdk_key
FLAGS_SECRET=base64-encoded-32-random-bytes

# Requeridas: cron e importación de jugadores desde Google Sheets
CRON_SECRET=change-this-to-a-long-random-cron-secret
GOOGLE_SHEETS_SPREADSHEET_ID=your-google-sheet-id
GOOGLE_SHEETS_TAB_NAME=Respuestas de formulario 1
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Opcionales (no se usan en el código actual MVP, pero útiles para próximas fases de auth)
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=change-me
